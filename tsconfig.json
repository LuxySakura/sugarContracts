/* Based on the official Hardhat 3 TypeScript template */
{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node16",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "outDir": "dist"
  },
  "exclude": ["artifacts", "cache", "dist", "node_modules", "types"]
}
